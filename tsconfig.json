{
	"compilerOptions": {
		"target": "ES2019",
		"module": "CommonJS",
		"moduleResolution": "node",
		"outDir": "./out/",
		"resolveJsonModule": true,
		"forceConsistentCasingInFileNames": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"removeComments": true,
		"sourceMap": true,
		"skipLibCheck": true
	},
	"include": ["./src/**/*.ts"]
}
